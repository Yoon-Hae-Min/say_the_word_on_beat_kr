# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Google service account keys (never commit)
google-service-account.json
*-service-account*.json
*-credentials*.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

supabase/migrations
supabase/seed.sql

# migration downloads
/migrations

# local-only docs
docs/local/
docs/reports/